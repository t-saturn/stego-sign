# stego-server — environment variables example
# Copy this file to .env and fill in your values

# -- database
# Opción 1: DATABASE_URL directo (recomendado en Docker)
DATABASE_URL=postgres://sre:your-password@localhost:5432/stegosign

# Opción 2: partes individuales (se construye DATABASE_URL si no está definido)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=stegosign
# POSTGRES_USER=sre
# POSTGRES_PASSWORD=your-password

# Levantar postgres local para desarrollo:
# docker run -d --name stego-db \
#   -e POSTGRES_USER=sre \
#   -e POSTGRES_PASSWORD=sre \
#   -e POSTGRES_DB=stegosign \
#   -p 55432:5432 postgres:17

# -- storage

# "aistor" para MinIO/AIStor local | "aws" para AWS S3
STORAGE_PROVIDER=aistor

# Prefijo de buckets — debe ser único globalmente en AWS S3
# Se crean: {prefix}-uploads, {prefix}-signatures, {prefix}-corrupted
STORAGE_BUCKET_PREFIX=stego-yourname

# Solo requerido con STORAGE_PROVIDER=aistor
STORAGE_ENDPOINT=http://localhost:9000

STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key

# -- server
SERVER_HOST=0.0.0.0
SERVER_PORT=4000
RUST_LOG=info

# -- signing keys — Ed25519
# Generarlas con: GET /api/v1/admin/keygen
SIGNING_KEY=   # Ed25519 private key PKCS8 base64
VERIFY_KEY=    # Ed25519 public key raw base64

# -- app
# URL base del frontend — usada para generar verify_url en QR watermark
APP_BASE_URL=http://localhost:3000
