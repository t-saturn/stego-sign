# stego-sign — environment variables example
# Copy this file to .env and fill in your values

# -- postgreSQL
POSTGRES_DB=stegosign
POSTGRES_USER=sre
POSTGRES_PASSWORD=your-secure-password

# -- storage
# "aistor" for local MinIO/AIStor | "aws" for AWS S3
STORAGE_PROVIDER=aistor

# required only when STORAGE_PROVIDER=aistor
# in Docker this points to the aistor container — leave as-is
STORAGE_ENDPOINT=http://aistor:9000

STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key

# bucket prefix — must be globally unique on AWS S3
# created buckets: {prefix}-uploads, {prefix}-signatures, {prefix}-corrupted
STORAGE_BUCKET_PREFIX=stego-yourname

# host ports for AIStor (only used when STORAGE_PROVIDER=aistor)
STORAGE_API_PORT=55545
STORAGE_CONSOLE_PORT=55546

# -- server
RUST_LOG=info

# generate with: curl http://localhost:4000/api/v1/admin/keygen
SIGNING_KEY=
VERIFY_KEY=

# -- app
APP_ENV=production          # production | development
APP_BASE_URL=http://localhost:55548
APP_PORT=55548

LEPTOS_OUTPUT_NAME=stego-app
LEPTOS_SITE_ROOT=site
LEPTOS_SITE_PKG_DIR=pkg